<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Nullable>enable</Nullable>

        <PackageId>WpfLikeAvaloniaMessageBox</PackageId>
        <Version>1.0.0</Version>
        <Authors>Net2Fox</Authors>
        <Description>Simple WPF-like MessageBox for Avalonia</Description>
        <PackageTags>avalonia;messagebox;wpf</PackageTags>
        <Copyright>Copyright (c) Net2Fox 2026</Copyright>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/Net2Fox/WpfLikeAvaloniaMessageBox</PackageProjectUrl>
        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/Net2Fox/WpfLikeAvaloniaMessageBox</RepositoryUrl>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Avalonia" Version="11.0.0" />
        <None Include="..\README.md" Pack="true" PackagePath=""/>
        <None Include="..\LICENSE" Pack="true" PackagePath=""/>
    </ItemGroup>
</Project>
